{
  "version": 1,
  "author": "Samuel",
  "editor": "wokwi",
  "parts": [
    {
      "id": "esp",
      "type": "wokwi-esp32-devkit-v1",
      "top": 40,
      "left": 40,
      "attrs": {}
    },
    {
      "id": "led1",
      "type": "wokwi-led",
      "top": 20,
      "left": 300,
      "attrs": { "color": "red" }
    }
  ],
  "connections": [
    [ "esp:TX0", "$serialMonitor:RX", "", [] ],
    [ "esp:RX0", "$serialMonitor:TX", "", [] ],
    [ "esp:D4", "led1:A", "green", [ "h120" ] ],
    [ "esp:GND.1", "led1:C", "black", [ "h80", "v-40" ] ]
  ],
  "serialMonitor": {
    "display": "always",
    "newline": "lf"
  }
}